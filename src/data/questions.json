  { "id": "alev-exp-001", "level": "alevel-maths", "topic": "pure", "subtopic": "Exponentials & Logarithms", "difficulty": 1, "question": "Solve:\n2ˣ = 32", "answer": "5", "answerLabel": "x = 5", "acceptedAnswers": ["5", "x=5", "x = 5"], "hints": ["Express 32 as a power of 2.", "32 = 2⁵", "x = 5"] },
