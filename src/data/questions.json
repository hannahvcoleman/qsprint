[
  { "id": "gcse-num-001", "level": "gcse-maths", "topic": "number", "subtopic": "Fractions & Decimals", "difficulty": 1, "question": "Work out:\n⅔ + ¾", "answer": "17/12", "answerLabel": "17/12 or 1 5/12", "acceptedAnswers": ["17/12", "1 5/12", "1.4167", "1.417"], "hints": ["To add fractions, you need a common denominator. What's the LCM of 3 and 4?", "LCM of 3 and 4 is 12.\n⅔ = 8/12\n¾ = 9/12", "⅔ + ¾\n= 8/12 + 9/12\n= 17/12\n= 1 5/12"] },
  { "id": "gcse-num-002", "level": "gcse-maths", "topic": "number", "subtopic": "Percentages", "difficulty": 1, "question": "A jacket costs £80. It is reduced by 15% in a sale.\nWhat is the sale price?", "answer": "68", "answerLabel": "£68", "acceptedAnswers": ["68", "£68", "68.00", "£68.00"], "hints": ["Find 15% of £80 first, then subtract.", "15% of £80: 10% = £8, 5% = £4, so 15% = £12", "Sale price = £80 − £12 = £68"] },
  { "id": "gcse-num-003", "level": "gcse-maths", "topic": "number", "subtopic": "Percentages", "difficulty": 2, "question": "A house was bought for £250,000.\nAfter year 1 it increased by 4%.\nAfter year 2 it decreased by 2%.\nWhat is the value after two years?", "answer": "254800", "answerLabel": "£254,800", "acceptedAnswers": ["254800", "£254800", "£254,800", "254,800"], "hints": ["Apply each change one at a time. 4% increase = ×1.04.", "Year 1: £250,000 × 1.04 = £260,000\nYear 2: £260,000 × 0.98 = ?", "£260,000 × 0.98 = £254,800"] },
  { "id": "gcse-num-004", "level": "gcse-maths", "topic": "number", "subtopic": "Ratio & Proportion", "difficulty": 1, "question": "Share £60 in the ratio 2 : 3", "answer": "24, 36", "answerLabel": "£24 and £36", "acceptedAnswers": ["24,36", "24 and 36", "£24 and £36", "24, 36", "36,24", "24:36", "24 36"], "hints": ["Find the total number of parts.", "Total parts = 5, one part = £60 ÷ 5 = £12", "First: 2 × £12 = £24\nSecond: 3 × £12 = £36"] },
  { "id": "gcse-num-005", "level": "gcse-maths", "topic": "number", "subtopic": "Standard Form", "difficulty": 2, "question": "Write 0.00045 in standard form.", "answer": "4.5 x 10^-4", "answerLabel": "4.5 × 10⁻⁴", "acceptedAnswers": ["4.5 x 10^-4", "4.5x10^-4", "4.5e-4", "4.5x10-4", "4.5X10^-4", "4.5*10^-4"], "hints": ["Standard form: A × 10ⁿ where 1 ≤ A < 10.", "Move decimal 4 places right → 4.5, power is negative.", "0.00045 = 4.5 × 10⁻⁴"] },
  { "id": "gcse-alg-001", "level": "gcse-maths", "topic": "algebra", "subtopic": "Linear Equations", "difficulty": 1, "question": "Solve for x:\n3x + 7 = 22", "answer": "5", "answerLabel": "x = 5", "acceptedAnswers": ["5", "x=5", "x = 5"], "hints": ["Subtract 7 from both sides.", "3x = 22 − 7 = 15", "x = 15 ÷ 3 = 5"] },
  { "id": "gcse-alg-002", "level": "gcse-maths", "topic": "algebra", "subtopic": "Linear Equations", "difficulty": 1, "question": "Solve:\n5(x − 2) = 3x + 4", "answer": "7", "answerLabel": "x = 7", "acceptedAnswers": ["7", "x=7", "x = 7"], "hints": ["Expand the brackets first.", "5x − 10 = 3x + 4\n2x = 14", "x = 7"] },
  { "id": "gcse-alg-003", "level": "gcse-maths", "topic": "algebra", "subtopic": "Quadratics", "difficulty": 2, "question": "Factorise and solve:\nx² + 5x + 6 = 0", "answer": "-2, -3", "answerLabel": "x = −2 or x = −3", "acceptedAnswers": ["-2,-3", "-3,-2", "-2 and -3", "-3 and -2", "-2 or -3"], "answerParts": [{ "patterns": ["-2", "−2"] }, { "patterns": ["-3", "−3"] }], "hints": ["Two numbers that multiply to +6 and add to +5.", "(x + 2)(x + 3) = 0", "x = −2 or x = −3"] },
  { "id": "gcse-alg-004", "level": "gcse-maths", "topic": "algebra", "subtopic": "Simultaneous Equations", "difficulty": 2, "question": "Solve simultaneously:\n2x + y = 7\nx − y = 2", "answer": "3, 1", "answerLabel": "x = 3, y = 1", "acceptedAnswers": ["3,1", "3, 1", "x=3 y=1", "x=3, y=1"], "answerParts": [{ "patterns": ["x=3", "x = 3"] }, { "patterns": ["y=1", "y = 1"] }], "hints": ["Add the two equations — what happens to y?", "3x = 9, so x = 3", "Sub into x − y = 2: y = 1"] },
  { "id": "gcse-alg-005", "level": "gcse-maths", "topic": "algebra", "subtopic": "Inequalities", "difficulty": 2, "question": "Solve:\n4x − 3 > 13", "answer": "x > 4", "answerLabel": "x > 4", "acceptedAnswers": ["x>4", "x > 4", ">4"], "hints": ["Treat it like an equation.", "4x > 16", "x > 4"] },
  { "id": "gcse-alg-006", "level": "gcse-maths", "topic": "algebra", "subtopic": "Sequences", "difficulty": 1, "question": "Find the nth term of:\n5, 8, 11, 14, 17, ...", "answer": "3n + 2", "answerLabel": "3n + 2", "acceptedAnswers": ["3n+2", "3n + 2", "2+3n", "2 + 3n"], "hints": ["Common difference = ?", "d = 3, so rule starts 3n. But 3×1=3, first term is 5, so add 2.", "nth term = 3n + 2"] },
  { "id": "gcse-geo-001", "level": "gcse-maths", "topic": "geometry", "subtopic": "Pythagoras", "difficulty": 2, "question": "A right-angled triangle has shorter sides of 5 cm and 12 cm.\nFind the hypotenuse.", "diagram": { "type": "right-triangle", "labelA": "5 cm", "labelB": "12 cm", "labelC": "x" }, "answer": "13", "answerLabel": "13 cm", "acceptedAnswers": ["13", "13cm", "13 cm"], "hints": ["a² + b² = c²", "25 + 144 = 169", "c = √169 = 13 cm"] },
  { "id": "gcse-geo-002", "level": "gcse-maths", "topic": "geometry", "subtopic": "Trigonometry", "difficulty": 2, "question": "The side opposite θ is 6 cm and the hypotenuse is 10 cm.\nFind θ to 1 d.p.", "diagram": { "type": "right-triangle-trig", "labelOpp": "6 cm", "labelHyp": "10 cm", "labelAngle": "θ" }, "answer": "36.9", "answerLabel": "θ = 36.9°", "acceptedAnswers": ["36.9", "36.9°", "36.87", "36.87°"], "hints": ["SOH CAH TOA — you have opp and hyp.", "sin θ = 6/10 = 0.6", "θ = sin⁻¹(0.6) = 36.9°"] },
  { "id": "gcse-geo-003", "level": "gcse-maths", "topic": "geometry", "subtopic": "Area & Perimeter", "difficulty": 1, "question": "A trapezium has parallel sides of 8 cm and 12 cm, and height 5 cm.\nFind the area.", "diagram": { "type": "trapezium", "labelTop": "8 cm", "labelBottom": "12 cm", "labelHeight": "5 cm" }, "answer": "50", "answerLabel": "50 cm²", "acceptedAnswers": ["50", "50cm2", "50 cm2", "50cm²", "50 cm²"], "hints": ["Area = ½ × (a + b) × h", "½ × (8 + 12) × 5 = ½ × 20 × 5", "= 50 cm²"] },
  { "id": "gcse-geo-004", "level": "gcse-maths", "topic": "geometry", "subtopic": "Angles", "difficulty": 1, "question": "Angles in a triangle are 50°, 70°, and x°.\nFind x.", "answer": "60", "answerLabel": "x = 60°", "acceptedAnswers": ["60", "60°", "x=60", "x = 60"], "hints": ["Angles in a triangle sum to 180°.", "50 + 70 + x = 180", "x = 60°"] },
  { "id": "gcse-sta-001", "level": "gcse-maths", "topic": "statistics", "subtopic": "Averages", "difficulty": 1, "question": "Find the mean of:\n4, 7, 11, 3, 15", "answer": "8", "answerLabel": "Mean = 8", "acceptedAnswers": ["8", "8.0"], "hints": ["Mean = sum ÷ count", "Sum = 40, count = 5", "Mean = 8"] },
  { "id": "gcse-sta-002", "level": "gcse-maths", "topic": "statistics", "subtopic": "Probability", "difficulty": 1, "question": "A bag has 3 red, 5 blue, 2 green marbles.\nWhat is P(blue)?", "answer": "1/2", "answerLabel": "P(blue) = ½", "acceptedAnswers": ["1/2", "0.5", "5/10", "50%"], "hints": ["P = favourable ÷ total", "Total = 10, blue = 5", "P = 5/10 = 1/2"] },
  { "id": "gcse-sta-003", "level": "gcse-maths", "topic": "statistics", "subtopic": "Probability", "difficulty": 2, "question": "Two dice are rolled. P(total = 7)?", "answer": "1/6", "answerLabel": "1/6", "acceptedAnswers": ["1/6", "6/36"], "hints": ["Total outcomes = 36. List combos for 7.", "(1,6)(2,5)(3,4)(4,3)(5,2)(6,1) = 6", "P = 6/36 = 1/6"] },
  { "id": "alev-dif-001", "level": "alevel-maths", "topic": "pure", "subtopic": "Differentiation", "difficulty": 1, "question": "Differentiate:\ny = 3x⁴ − 2x² + 5x − 1", "answer": "12x^3 - 4x + 5", "answerLabel": "dy/dx = 12x³ − 4x + 5", "acceptedAnswers": ["12x^3 - 4x + 5", "12x³ - 4x + 5", "12x^3-4x+5"], "hints": ["Power rule: d/dx(xⁿ) = nxⁿ⁻¹", "3x⁴→12x³, −2x²→−4x, 5x→5, −1→0", "dy/dx = 12x³ − 4x + 5"] },
  { "id": "alev-dif-002", "level": "alevel-maths", "topic": "pure", "subtopic": "Differentiation", "difficulty": 2, "question": "Find dy/dx if:\ny = (2x + 3)⁵", "answer": "10(2x+3)^4", "answerLabel": "dy/dx = 10(2x + 3)⁴", "acceptedAnswers": ["10(2x+3)^4", "10(2x + 3)^4", "10(2x+3)⁴"], "hints": ["Chain rule.", "u = 2x+3, dy/du = 5u⁴, du/dx = 2", "dy/dx = 10(2x + 3)⁴"] },
  { "id": "alev-dif-003", "level": "alevel-maths", "topic": "pure", "subtopic": "Differentiation", "difficulty": 2, "question": "Find stationary points of:\ny = x³ − 6x² + 9x + 1", "answer": "x=1 and x=3", "answerLabel": "(1, 5) and (3, 1)", "acceptedAnswers": ["x=1, x=3", "1, 3", "x=1 and x=3", "(1,5) and (3,1)"], "answerParts": [{ "patterns": ["x=1", "(1,5)"] }, { "patterns": ["x=3", "(3,1)"] }], "hints": ["Set dy/dx = 0.", "3x² − 12x + 9 = 0 → 3(x−1)(x−3) = 0", "x=1: y=5 → (1,5)\nx=3: y=1 → (3,1)"] },
  { "id": "alev-int-001", "level": "alevel-maths", "topic": "pure", "subtopic": "Integration", "difficulty": 1, "question": "Find:\n∫(4x³ + 6x − 2) dx", "answer": "x^4 + 3x^2 - 2x + C", "answerLabel": "x⁴ + 3x² − 2x + C", "acceptedAnswers": ["x^4 + 3x^2 - 2x + C", "x^4 + 3x^2 - 2x + c", "x^4+3x^2-2x+C"], "hints": ["Increase power by 1, divide by new power. +C.", "4x³→x⁴, 6x→3x², −2→−2x", "x⁴ + 3x² − 2x + C"] },
